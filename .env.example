# OpSoul environment variables — example template
#
# Copy this to `.env` (not committed) and fill in values for the
# services you want enabled. Empty / missing values disable the
# corresponding capability gracefully.

# ─── Core ─────────────────────────────────────────────────────────────────
DATABASE_URL=                            # postgres://...
JWT_SECRET=                              # long random string

# ─── LLM substrates (OpenRouter is primary) ───────────────────────────────
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=

# ─── Web search (Serper.dev — used by web_search tool) ────────────────────
SERPER_API_KEY=

# ─── Firecrawl (Wave 4 — D-6 Free tier approved 2026-05-31) ───────────────
# Get a free key at https://www.firecrawl.dev/.
# Free tier: 500 pages/month, 15 req/min, 10 concurrent.
# Gates the firecrawl_scrape / _map / _crawl / _extract / _search tools.
FIRECRAWL_API_KEY=
# Optional overrides — leave blank to use defaults.
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_MAX_CONCURRENT=10
