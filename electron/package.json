{
  "name": "opsoul-desktop",
  "version": "0.1.0",
  "description": "OpSoul Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "embedded-postgres": "^18.4.0-beta.17"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "dev.opsoul.desktop",
    "productName": "OpSoul",
    "copyright": "Copyright © 2026 OpSoul",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../artifacts/opsoul-api",
        "to": "server",
        "filter": ["**/*", "!node_modules"]
      },
      {
        "from": "../artifacts/opsoul-api/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "../artifacts/opsoul-hub/dist/public",
        "to": "server/public"
      },
      {
        "from": "docs",
        "to": "docs"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
