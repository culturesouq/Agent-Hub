{
  "name": "@opsoul/client",
  "version": "0.1.0",
  "description": "Official client for self-hosted OpSoul servers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nahil": {
      "import": "./dist/operators/nahil.js",
      "require": "./dist/operators/nahil.cjs",
      "types": "./dist/operators/nahil.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/operators/nahil.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/operators/nahil.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
