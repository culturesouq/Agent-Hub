# OpSoul — Self-hosted configuration
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────
# Your AI model API key (OpenRouter is the primary substrate)
OPENROUTER_API_KEY=

# Base URL for OpenRouter (default is fine — only change if using a proxy)
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Security: generate with: openssl rand -hex 32
JWT_SECRET=
DB_PASSWORD=changeme_generate_a_strong_password

# Your server's public URL (used for OAuth callbacks, email links)
APP_URL=http://localhost:3001
APP_BASE_URL=http://localhost:3001

# Admin account granted sovereign-admin rights on first run
SOVEREIGN_ADMIN_EMAIL=admin@yourcompany.com

# ── Optional ───────────────────────────────────────────
# Web search tool (get a free key at https://serper.dev)
SERPER_API_KEY=

# Firecrawl — web scraping tool (free tier: 500 pages/month)
# Get a key at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Email sending via SendGrid (leave empty to disable email features)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Privacy contact shown in transactional emails
PRIVACY_EMAIL=

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# CORS: comma-separated list of allowed origins, or * to allow all
# Leave blank to use default (localhost only in dev, strict in prod)
ALLOWED_ORIGIN=

# ── Advanced ───────────────────────────────────────────
PORT=3001
